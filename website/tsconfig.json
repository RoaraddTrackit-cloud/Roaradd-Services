{
    "include": ["src/**/*"],
    "exclude": ["node_modules", "build", "dist", "**/*.test.ts"],
    "compilerOptions": {
          "target": "ESNext",
          "useDefineForClassFields": true,
          "lib": ["esnext", "dom", "dom.iterable"],
          "module": "ESNext",
          "skipLibCheck": true,
          "noEmit": true,
          "jsx": "react-jsx",
          "strict": true,
          "resolveJsonModule": true,
          "allowImportingTsExtensions": true,
          "moduleResolution": "bundler",
          "types": ["node", "vite/client"],
          "paths": {
                  "@/*": ["./src/*"]
          }
    }
}
